{
  "families": {
    "display": "\"Playfair Display\", Georgia, serif",
    "sans":    "\"Roboto\", system-ui, sans-serif",
    "mono":    "\"JetBrains Mono\", monospace"
  },
  "sizes": {
    "xs":  "0.75rem",
    "sm":  "0.875rem",
    "base": "1rem",
    "lg":  "1.125rem",
    "xl":  "1.25rem",
    "2xl": "1.5rem",
    "3xl": "1.875rem",
    "5xl": "3rem",
    "6xl": "3.75rem"
  },
  "weights": {
    "normal":   400,
    "medium":   500,
    "semibold": 600,
    "bold":     700
  },
  "lineHeights": {
    "none":    1,
    "tight":   1.25,
    "snug":    1.375,
    "relaxed": 1.625
  },
  "letterSpacing": {
    "wide":   "0.025em",
    "widest": "0.1em"
  }
}
